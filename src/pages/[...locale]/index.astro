---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SiteNav from '../../components/SiteNav.astro'
import Hero from '../../components/landing/Hero.astro'
import Features from '../../components/landing/Features.astro'
import DownloadCTA from '../../components/landing/DownloadCTA.astro'
import { locales, blogBase, docsBase, t } from '../../i18n'

export function getStaticPaths() {
  return locales.map(({ locale, lang }) => ({ params: { locale }, props: { lang } }))
}

const { lang } = Astro.props
const i18n = t(lang)
---

<BaseLayout title={i18n.landingTitle} description={i18n.landingDescription} lang={lang}>

  <!-- Page-level canvas dot-grid (background-image overlays body's solid #0D0D0D) -->
  <div style="background-image: radial-gradient(circle, rgba(43,46,51,0.6) 1px, transparent 1px); background-size: 24px 24px;">

  <SiteNav lang={lang} />

  <main>
    <Hero lang={lang} />
    <Features lang={lang} />
    <DownloadCTA lang={lang} />
  </main>

  <footer class="border-t border-white/5 px-6 py-8">
    <div class="max-w-6xl mx-auto flex flex-col gap-5 text-xs text-on-surface-variant/40">

      <!-- Single row: copyright left · icons center · made by right -->
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-0">
        <span class="sm:flex-1">{i18n.footerCopy}</span>

        <div class="flex items-center gap-4">
          <a
            href="https://github.com/karn-mtg/forge"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="hover:text-on-surface-variant transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
          <a
            href="https://discord.gg/Y7t68pRnea"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Discord"
            class="hover:text-[#5865F2] transition-colors"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.002.022.015.043.03.056a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
          </a>
        </div>

        <span class="sm:flex-1 sm:text-right flex items-center justify-center sm:justify-end gap-1">
          {i18n.footerMadeBy}
          <a
            href="https://instagram.com/guidimtg"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-on-surface-variant transition-colors underline underline-offset-2"
          >@guidimtg</a>
        </span>
      </div>

      <!-- WotC disclaimer -->
      <p class="text-center text-on-surface-variant/25 leading-relaxed max-w-3xl mx-auto">
        {i18n.footerDisclaimer}
      </p>

    </div>
  </footer>

  </div>{/* end dot-grid wrapper */}

<script>
  const scrollEls = document.querySelectorAll<HTMLElement>('[data-scroll]')

  scrollEls.forEach(el => el.classList.add('scroll-hidden'))

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return
      const delay = parseInt(entry.target.getAttribute('data-scroll-delay') ?? '0') * 80
      setTimeout(() => {
        entry.target.classList.remove('scroll-hidden')
        entry.target.classList.add('scroll-visible')
      }, delay)
      observer.unobserve(entry.target)
    })
  }, { threshold: 0.08 })

  scrollEls.forEach(el => observer.observe(el))
</script>

</BaseLayout>
