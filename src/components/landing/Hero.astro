---
import { t, docsBase, blogBase, type Lang } from '../../i18n'

interface Props {
  lang?: Lang
}

const { lang = 'en' } = Astro.props
const i18n = t(lang)

const badges = [
  { key: 'forge',    label: 'Forge',    repo: 'karn-mtg/forge', prefix: null,       pulse: true  },
  { key: 'arsenal',  label: 'Arsenal',  repo: 'karn-mtg/karn',  prefix: 'server-',  pulse: false },
  { key: 'cards-db', label: 'Cards DB', repo: 'karn-mtg/karn',  prefix: 'cards-db-',pulse: false },
  { key: 'rules-db', label: 'Rules DB', repo: 'karn-mtg/karn',  prefix: 'rules-db-',pulse: false },
  { key: 'karn',     label: 'Karn AI',  repo: 'karn-mtg/karn',  prefix: 'agent-',   pulse: true  },
]
---

<section class="relative z-10 min-h-[92vh] flex items-center justify-center px-6 pt-24 pb-8 lg:pb-0">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 90% 60% at 50% 0%, rgba(242,202,131,0.07) 0%, transparent 65%);"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <!-- App icon -->
    <div class="flex justify-center mb-8">
      <img
        src="/icon.png"
        alt="Karn Forge"
        class="w-28 h-28 rounded-3xl shadow-2xl shadow-primary/20 ring-1 ring-primary/20"
      />
    </div>

    <!-- Component version badges -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-10">
      {badges.map((c) => (
        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border border-white/10 bg-white/5 text-on-surface-variant text-xs font-medium select-none">
          {c.pulse && <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse flex-shrink-0"></span>}
          <span class="text-on-surface font-semibold">{c.label}</span>
          <span class="text-primary/80 font-mono" data-version-repo={c.repo} data-version-prefix={c.prefix ?? ''}>{c.repo ? '...' : '—'}</span>
        </div>
      ))}
    </div>

    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.08]">
      <span class="block text-on-surface">{i18n.heroHeadlineTop}</span>
      <span class="block text-primary">{i18n.heroHeadlineBottom}</span>
    </h1>

    <p class="mt-6 text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
      {i18n.heroSub}
    </p>

    <div class="mt-10 flex flex-col items-center gap-2 w-full max-w-sm mx-auto">
      <!-- Small nav row -->
      <div class="flex gap-2 w-full">
        <a
          href={docsBase(lang)}
          class="flex-1 text-center py-2.5 rounded-xl border border-white/10 text-on-surface-variant font-semibold text-xs hover:bg-white/5 hover:text-on-surface transition-all duration-200"
        >
          {i18n.heroDocs}
        </a>
        <a
          href={blogBase(lang)}
          class="flex-1 text-center py-2.5 rounded-xl border border-white/10 text-on-surface-variant font-semibold text-xs hover:bg-white/5 hover:text-on-surface transition-all duration-200"
        >
          {i18n.navBlog}
        </a>
      </div>
      <!-- Big download button -->
      <a
        href="https://github.com/karn-mtg/forge/releases"
        class="w-full text-center py-4 rounded-xl bg-primary text-on-primary font-bold text-base hover:bg-primary-container transition-all duration-200 shadow-xl shadow-primary/25"
      >
        {i18n.heroCta}
      </a>
    </div>
    <p class="mt-3 text-xs text-on-surface-variant/40">{i18n.heroCtaSub}</p>
  </div>

  <!-- Scroll indicator -->
  <div id="scroll-indicator" class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 transition-opacity duration-500">
    <div class="w-6 h-10 rounded-full border-2 border-white/50 flex justify-center pt-2">
      <div class="w-1 h-2 rounded-full bg-white/80 scroll-wheel"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scrollWheel {
    0%   { opacity: 1; transform: translateY(0); }
    60%  { opacity: 0; transform: translateY(8px); }
    61%  { opacity: 0; transform: translateY(0); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .scroll-wheel {
    animation: scrollWheel 1.8s ease-in-out infinite;
  }
</style>

<script>
  const scrollIndicator = document.getElementById('scroll-indicator')
  if (scrollIndicator) {
    window.addEventListener('scroll', () => {
      scrollIndicator.style.opacity = '0'
      scrollIndicator.style.pointerEvents = 'none'
    }, { once: true })
  }

  type GHRelease = { tag_name: string }

  const releaseCache = new Map<string, Promise<GHRelease[]>>()

  function fetchReleases(repo: string): Promise<GHRelease[]> {
    if (!releaseCache.has(repo)) {
      releaseCache.set(repo, fetch(
        `https://api.github.com/repos/${repo}/releases?per_page=20`,
        { headers: { Accept: 'application/vnd.github.v3+json' } }
      ).then(r => r.ok ? r.json() : []).catch(() => []))
    }
    return releaseCache.get(repo)!
  }

  const badges = document.querySelectorAll<HTMLElement>('[data-version-repo]')

  for (const el of badges) {
    const repo = el.dataset.versionRepo
    const prefix = el.dataset.versionPrefix ?? ''
    if (!repo) continue

    fetchReleases(repo).then(releases => {
      const match = releases.find(r => r.tag_name.startsWith(prefix))
      el.textContent = match ? match.tag_name.slice(prefix.length) : '—'
    })
  }
</script>
