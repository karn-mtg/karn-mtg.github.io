---
import { t, type Lang } from '../../i18n'

interface Props {
  lang?: Lang
}

const { lang = 'en' } = Astro.props
const i18n = t(lang)
---

<section class="px-6 py-24">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-on-surface">{i18n.featuresHeading}</h2>
      <p class="mt-3 text-on-surface-variant">{i18n.featuresSubheading}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {i18n.features.map((f) => (
        <div class="glass-panel rounded-2xl p-6 hover:border-primary/30 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/5">
          <div class="text-3xl mb-4 select-none">{f.icon}</div>
          <h3 class="font-bold text-on-surface mb-2">{f.title}</h3>
          <p class="text-sm text-on-surface-variant leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
