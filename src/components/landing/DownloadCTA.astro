---
import { t, blogBase, downloadBase, type Lang } from '../../i18n'

interface Props {
  lang?: Lang
}

const { lang = 'en' } = Astro.props
const i18n = t(lang)
---

<section class="px-6 py-14">
  <div class="max-w-2xl mx-auto" data-scroll>
    <div class="glass-panel rounded-3xl p-6 sm:p-10 md:p-12 text-center relative">
      <div
        class="absolute inset-0 rounded-3xl pointer-events-none"
        style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(242,202,131,0.06) 0%, transparent 70%);"
      ></div>

      <h2 class="text-3xl font-bold text-on-surface relative">{i18n.ctaHeading}</h2>
      <p class="mt-4 text-on-surface-variant relative">{i18n.ctaSub}</p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center relative">
        <a
          href={downloadBase(lang)}
          class="px-7 py-3.5 rounded-xl bg-primary text-on-primary font-bold text-sm hover:bg-primary-container transition-all duration-200 shadow-lg shadow-primary/20"
        >
          {i18n.ctaButton}
        </a>
        <a
          href={blogBase(lang)}
          class="px-7 py-3.5 rounded-xl border border-white/10 text-on-surface-variant font-bold text-sm hover:bg-white/5 hover:text-on-surface transition-all duration-200"
        >
          {i18n.ctaBlog}
        </a>
      </div>
    </div>
  </div>
</section>
