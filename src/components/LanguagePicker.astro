---
import 'flag-icons/css/flag-icons.min.css'
import { languages, locales, type Lang } from '../i18n'

interface Props {
  currentLang: Lang
}

const { currentLang } = Astro.props
const currentPath = Astro.url.pathname

const nonDefaultPrefixes = locales
  .filter(l => l.locale !== undefined)
  .map(l => l.locale as string)

let basePath = currentPath
for (const prefix of nonDefaultPrefixes) {
  if (currentPath.startsWith(`/${prefix}/`) || currentPath === `/${prefix}`) {
    basePath = currentPath.slice(prefix.length + 1) || '/'
    break
  }
}

function switchUrl(lang: Lang): string {
  if (lang === 'en') return basePath || '/'
  return `/${lang}${basePath === '/' ? '' : basePath}`
}

const current = languages[currentLang]
---

<details class="lang-picker relative">
  <summary class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-white/10 bg-surface-container/50 text-xs font-semibold text-on-surface-variant hover:text-on-surface hover:bg-white/5 cursor-pointer transition-colors duration-200 select-none" style="list-style: none;">
    <span class={`fi fi-${current.flagCode} text-base leading-none`}></span>
    <span class="hidden sm:block">{current.label}</span>
    <svg class="w-3 h-3 opacity-40 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>

  <div class="absolute right-0 top-full mt-2 w-44 glass-panel rounded-xl overflow-hidden z-50 shadow-2xl shadow-black/40 border border-white/10">
    {Object.entries(languages).map(([lang, { flagCode, label }]) => {
      const isActive = lang === currentLang
      return (
        <a
          href={switchUrl(lang as Lang)}
          class:list={[
            'flex items-center gap-3 px-4 py-2.5 text-xs font-semibold transition-colors duration-150',
            isActive
              ? 'text-primary bg-primary/10'
              : 'text-on-surface-variant hover:text-on-surface hover:bg-white/5',
          ]}
        >
          <span class={`fi fi-${flagCode} text-base leading-none`}></span>
          <span class="flex-1">{label}</span>
          {isActive && (
            <svg class="w-3.5 h-3.5 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
          )}
        </a>
      )
    })}
  </div>
</details>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; }
</style>

<script>
  document.addEventListener('click', (e) => {
    document.querySelectorAll<HTMLDetailsElement>('details.lang-picker[open]').forEach(el => {
      if (!el.contains(e.target as Node)) el.open = false
    })
  })
</script>
