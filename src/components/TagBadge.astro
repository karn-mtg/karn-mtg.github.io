---
interface Props {
  tag: string
  lang?: string
  active?: boolean
}

const { tag, lang = 'en', active = false } = Astro.props
const href = lang === 'pt-br' ? `/pt-br/blog/tags/${encodeURIComponent(tag)}` : `/blog/tags/${encodeURIComponent(tag)}`
---

<a
  href={href}
  class:list={[
    'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold transition-colors duration-150 whitespace-nowrap',
    active
      ? 'bg-primary text-on-primary'
      : 'bg-primary/10 text-primary hover:bg-primary/20 border border-primary/20',
  ]}
>
  {tag}
</a>
