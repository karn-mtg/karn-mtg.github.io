---
import TagBadge from './TagBadge.astro'
import { t, blogBase, type Lang } from '../i18n'

interface Props {
  title: string
  description: string
  date: string
  slug: string
  lang?: Lang
  image?: string
  tags?: string[]
  authorName?: string
  authorId?: string
}

const { title, description, date, slug, lang = 'en', image, tags = [], authorName, authorId } = Astro.props
const i18n = t(lang)
const href = `${blogBase(lang)}/${slug}`
const authorHref = authorId ? `${blogBase(lang)}/authors/${authorId}` : null
const formattedDate = new Date(date).toLocaleDateString(i18n.dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<a href={href} class="group block">
  <article class="glass-panel rounded-2xl overflow-hidden transition-all duration-300 hover:border-primary/30 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/5">
    {image ? (
      <div class="aspect-[16/7] overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    ) : (
      <div class="aspect-[16/7] bg-gradient-to-br from-primary/10 via-surface to-surface-container flex items-center justify-center border-b border-white/5">
        <svg class="w-10 h-10 text-primary/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}

    <div class="p-6">
      <div class="flex items-center justify-between gap-3 mb-3">
        <time class="text-xs font-semibold uppercase tracking-widest text-on-surface-variant/60">
          {formattedDate}
        </time>
        {authorName && authorHref && (
          <a
            href={authorHref}
            class="text-xs text-on-surface-variant/60 hover:text-primary transition-colors"
            onclick="event.stopPropagation()"
          >
            {authorName}
          </a>
        )}
      </div>

      <h2 class="text-lg font-bold text-on-surface group-hover:text-primary transition-colors duration-200 leading-snug">
        {title}
      </h2>
      <p class="mt-2 text-sm text-on-surface-variant leading-relaxed line-clamp-2">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5" onclick="event.stopPropagation()">
          {tags.map(tag => <TagBadge tag={tag} lang={lang} />)}
        </div>
      )}

      <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-200">
        {i18n.readMore} →
      </span>
    </div>
  </article>
</a>
